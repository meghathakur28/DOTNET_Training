@model FlightSearchEngine.Models.SearchViewModel

@{
    ViewData["Title"] = "Flight Search";
}

<div class="container mt-4">
    <h2 class="mb-4">✈️ Flight Search Engine</h2>

    <form method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label class="form-label">Source City</label>
            <select asp-for="Source" asp-items="Model.SourceList" class="form-select">
                <option value="">-- Select Source --</option>
            </select>
            <span asp-validation-for="Source" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Destination City</label>
            <select asp-for="Destination" asp-items="Model.DestinationList" class="form-select">
                <option value="">-- Select Destination --</option>
            </select>
            <span asp-validation-for="Destination" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Number of Persons</label>
            <input asp-for="NumberOfPersons" type="number" class="form-control" min="1" max="10" placeholder="Enter number of persons" />
            <span asp-validation-for="NumberOfPersons" class="text-danger"></span>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="d-flex gap-3">
            <button type="submit" asp-action="SearchFlights" class="btn btn-success" id="btnFlights">
                Search Flights Only
            </button>
            <button type="submit" asp-action="SearchFlightsWithHotels" class="btn btn-warning" id="btnHotels">
                Search Flight + Hotel
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.querySelector("form").addEventListener("submit", function (e) {
            var source = document.getElementById("Source").value;
            var dest = document.getElementById("Destination").value;

            if (source !== "" && dest !== "" && source === dest) {
                e.preventDefault();
                alert("Source and Destination cannot be the same city!");
            }
        });
    </script>
}